	<parameter name="reportHomePath" class="java.lang.String" isForPrompting="false"/>
	<parameter name="fechaini" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["15-04-2009"]]></defaultValueExpression>
	</parameter>
	<parameter name="fechafin" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["15-07-2010"]]></defaultValueExpression>
	</parameter>
	<parameter name="clave_cliente" class="java.lang.String" isForPrompting="false"/>
	<parameter name="id_servicio" class="java.lang.String" isForPrompting="false"/>
	<parameter name="id_fuente" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["32"]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[select cv_negocio,dc_negocio
               ,BANCO,NOMBRE_CORTO
               ,SERVICIO,descripcion               
               ,MT_DISPENSADO_DLS MT_DISPENSADO_DLS
               ,MT_DISPENSADO_PS
               ,MT_CROSSBORDER_DLS MT_CROSSBORDER_DLS  
               ,round(SUBTOTAL_COBDIA/MT_CROSSBORDER_DLS,4)TIPO_CAMBIO             
               ,(SUBTOTAL_COBDIA) MT_CROSSBORDER_PS
               ,(IVA_COBDIA) IVA
               ,(TOTAL_COBDIA) TOTAL
               from (
                    select n.clave cv_negocio,n.descripcion dc_negocio
                     ,cr.BANCO,c.NOMBRE_CORTO
                     ,cr.SERVICIO,s.descripcion
                     ,c.PCT_IVA/100 PCT_IVA                    
                     ,sum(cd.SUBTOTAL_COBDIA/.004)  MT_DISPENSADO_PS
                     ,round(sum(cr.mt_crossborder),2) MT_CROSSBORDER_DLS
                     ,round(sum(cr.mt_dispensado_dls),2) MT_DISPENSADO_DLS                     
                     ,sum(cd.SUBTOTAL_COBDIA) SUBTOTAL_COBDIA
                     ,sum(cd.IVA_COBDIA) IVA_COBDIA
                     ,sum(cd.TOTAL_COBDIA) TOTAL_COBDIA                      
                    from tbl_sif_servicios s
                     ,tbl_sif_cat_clientes c
                     ,tbl_sif_fuentes f
                     ,tbl_sif_rep_cross cr
                     ,tbl_sif_cat_negocios n
                     ,v_sif_cobranza_diaria cd
                    where f.id_fuente = s.id_fuente
                      and cd.CLAVE_CLIENTE =c.clave_cliente
                      and cd.CLAVE_SERVICIO=s.clave
                      and cd.CLAVE_NEGOCIO=n.CLAVE
                      and trunc(cd.FECHA_DATOS) between to_date($P{fechaini},'yyyy/mm/dd') and to_date($P{fechafin},'yyyy/mm/dd')
                      and trunc(cd.FECHA_DATOS) = trunc(cr.FECHA_DATOS)
                      and cr.servicio = s.clave
                      and cr.banco = c.clave_cliente
                      and s.id_negocio = n.id_negocio
                      and f.id_fuente = $P{id_fuente}
		      and c.clave_cliente = nvl($P{clave_cliente},c.clave_cliente)
		      and s.clave = nvl($P{id_servicio},s.clave)
                      and s.estatus = 'ACT' 
                      and c.estatus = 'ACT' 
                      and f.estatus = 'ACT' 
                      group by  n.clave,n.descripcion,cr.SERVICIO,s.descripcion, cr.BANCO,c.NOMBRE_CORTO,c.PCT_IVA 
                       )
                  order by 1,3]]>
	</queryString>
