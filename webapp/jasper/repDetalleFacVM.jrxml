	<queryString language="SQL">
		<![CDATA[select process_date fechaDatos,clave_cliente claveCliente,nombre_corto nombreCliente,clave_servicio claveServicio,descripcion nombreServicio,
invoice_date fechaFactura,invoice_to facturarA,event_code codigo, event_description concepto, fuente marca,fiid, adq_iss_flag adqEmi, qa_flag qa,
quantity transacciones, rate precio, charge cargo, total_charge monto
from view_sif_rep_fac_vm
where process_date between to_date($P{fechaini},'yyyy/mm/dd') and to_date($P{fechafin},'yyyy/mm/dd')
and clave_cliente = nvl($P{clave_cliente},clave_cliente)
and clave_servicio = nvl($P{id_servicio},clave_servicio)
order by 1,2,4]]>
	</queryString>
