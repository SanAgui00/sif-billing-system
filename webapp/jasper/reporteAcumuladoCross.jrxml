	<parameter name="clave_cliente" class="java.lang.String" isForPrompting="false"/>
	<parameter name="id_fuente" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["32"]]></defaultValueExpression>
	</parameter>
	<parameter name="id_servicio" class="java.lang.String" isForPrompting="false"/>
	<parameter name="fechaini" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["01/11/2015"]]></defaultValueExpression>
	</parameter>
	<parameter name="fechafin" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["30/11/2015"]]></defaultValueExpression>
	</parameter>
	<parameter name="reportHomePath" class="java.lang.String" isForPrompting="false"/>
	<queryString language="SQL">
		<![CDATA[select clave_cliente,desc_cliente
,clave_servicio,desc_servicio
,trunc(fecha_datos) fecha_datos,precio
,sum(decode(tipo_mensaje,'0420',0,base_cross)) monto_aprobado
,sum(base_cross) monto_base
,sum(monto_cross) monto_cross
from tbl_sif_rep_cbr
where fecha_datos between to_date($P{fechaini},'yyyy/mm/dd') and to_date($P{fechafin},'yyyy/mm/dd')
and clave_cliente = nvl($P{clave_cliente},clave_cliente)
and clave_servicio = nvl($P{id_servicio},clave_servicio)
group by clave_cliente,desc_cliente
,clave_servicio,desc_servicio
,fecha_datos,precio
order by 1,3,5]]>
	</queryString>
