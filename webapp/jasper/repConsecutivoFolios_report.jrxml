	<parameter name="reportHomePath" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pFechaInicial" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["28/05/2014"]]></defaultValueExpression>
	</parameter>
	<parameter name="pFechaFinal" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["30/01/2017"]]></defaultValueExpression>
	</parameter>
	<parameter name="pClaveCliente" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pClaveNegocio" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pEstatus" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pClaveMoneda" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pSerie" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pTipoDocumento" class="java.lang.String" isForPrompting="false"/>
	<parameter name="pClaveProceso" class="java.lang.String" isForPrompting="false"/>
	<queryString language="SQL">
		<![CDATA[select FOLIO_IMPRESO, FOLIO_INTERNO, decode(TIPO_DOCUMENTO,'SER','FACTURA DE SERVICIOS','ABI','FACTURA ABIERTA','NOT','NOTA DE CREDITO','OTRO DOCUMENTO') TIPO_DOCUMENTO, CLAVE_PROCESO, DESC_PROCESO, CLAVE_NEGOCIO, DESC_NEGOCIO, RFC, CLAVE_CLIENTE, RAZON_SOCIAL, NOMBRE_CORTO, DOMICILIO, CANTIDAD, CONCEPTO, NOMBRE_MONEDA, PRECIO_UNITARIO, SUBTOTAL, SUBTOTAL_DESC, IVA, TOTAL, TIPO_CAMBIO, FECHA_RESERVACION, FECHA_IMPRESION, FECHA_COBRO, ESTATUS, REFERENCIA, COMENTARIOS, FECHA_FACTURA, ID_GENERADO_GL, CUENTA_CLIENTE, ESTATUS_COBRO, CLAVE_CATEGORIA_INGRESO, CUENTA_INGRESO, CENTRO_COSTOS, CLAVE_SERVICIO_PARTICULAR, CLAVE_SERVICIO, TEMPORAL 
from view_sif_consecutivo_folios
where fecha_factura between to_date('2000-03-09','yyyy/mm/dd') and to_date('2018-09-21','yyyy/mm/dd')
and clave_proceso = nvl('CROSS',clave_proceso)
and clave_negocio = nvl('RED_CROSS_ADQ',clave_negocio)
and clave_cliente = nvl('BC003',clave_cliente)
and nombre_moneda = nvl('PESO',nombre_moneda)
and tipo_documento = nvl('SER',tipo_documento)
and serie = nvl('A',serie)
and estatus = nvl('IMP',estatus)
order by 1
]]>
	</queryString>
