	<parameter name="fecha_ini" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy").parse("01/03/2007")]]></defaultValueExpression>
	</parameter>
	<parameter name="fecha_fin" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy",new Locale("es","MX")).parse("31/03/2007")]]></defaultValueExpression>
