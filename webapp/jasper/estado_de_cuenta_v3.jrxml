	<parameter name="reportHomePath" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[Select $P{fecha_ini} fecha_ini,
$P{fecha_fin} fecha_fin
,$P{id_moneda} id_moneda
,$P{clave_cliente} clave_cliente
,$P{id_proceso} id_proceso
,$P{id_negocio} id_negocio
,ec.cv_negocio clave_negocio
,ec.nm_negocio nombre_negocio
,ec.semana semana
,ec.id_empresa
from tbl_sif_estado_cuenta ec
Where ec.fecha_datos BETWEEN Pk_Sif_Dias_Periodo.obt_rango_edocta($P{fecha_ini},'MIN') AND Pk_Sif_Dias_Periodo.obt_rango_edocta($P{fecha_fin},'MAX')
And ec.id_moneda = $P{id_moneda}
And ec.id_proceso = $P{id_proceso}
And ec.id_negocio = $P{id_negocio}
And ec.cv_cliente = $P{clave_cliente}
GROUP BY ec.cv_negocio,
ec.nm_negocio,
ec.semana,ec.id_empresa
order by ec.cv_negocio,ec.semana]]>
	</queryString>
