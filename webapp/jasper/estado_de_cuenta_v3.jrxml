	<subDataset name="SubDataset1" uuid="1a5ecd33-c920-4f3f-9909-fee8dc4511af">
		<parameter name="clave_negocio" class="java.lang.String" isForPrompting="false"/>
		<parameter name="semana" class="java.math.BigDecimal" isForPrompting="false"/>
		<parameter name="fecha_ini" class="java.util.Date" isForPrompting="false"/>
		<parameter name="fecha_fin" class="java.util.Date" isForPrompting="false"/>
		<parameter name="id_moneda" class="java.lang.Long" isForPrompting="false"/>
		<parameter name="clave_cliente" class="java.lang.String" isForPrompting="false"/>
		<parameter name="id_proceso" class="java.lang.Long" isForPrompting="false">
			<defaultValueExpression><![CDATA[new Long(1)]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT det.id_moneda 
      ,det.id_cliente 
	  ,det.clave_cliente 
      ,det.nombre_cliente 
	  ,det.clave_negocio 
	  ,det.nombre_negocio 
	  ,det.id_servicio 
	  ,det.clave_servicio 
	  ,det.semana 
	  ,det.fecha 
      ,det.dia 
	  ,det.fecha_cobro 
	  ,COUNT(1)
	  ,SUM(det.trx) trx 
	  ,det.precio 
	  ,det.tipo_cambio 
	  ,SUM(det.importe) importe 
  	  ,SUM(det.iva) iva 
      ,SUM(det.total) total
      ,SUM(det.trx_ajuste_cont) trx_ajuste_cont 
	  ,SUM(det.imp_ajuste_cont) imp_ajuste_cont 
FROM ( 
SELECT ec.id_moneda 
      ,ec.id_cliente 
	  ,ec.cv_cliente clave_cliente 
      ,ec.nm_cliente nombre_cliente 
	  ,ec.cv_negocio clave_negocio 
	  ,ec.nm_negocio nombre_negocio 
	  ,ec.id_servicio 
	  ,ec.cv_servicio||' '|| INITCAP(nm_servicio) clave_servicio 
	  ,ec.semana 
	  ,ec.fecha_datos fecha 
      ,ec.dia 
	  ,ec.fecha_cobro 
	  ,ec.trx_cobdia trx 
	  ,ec.precio 
	  ,ec.tipo_cambio 
	  ,ec.importe_cobdia importe 
  	  ,ec.iva_cobdia iva 
      ,ec.total_cobdia total 
      ,ec.trx_ajuste_cont 
	  ,ec.imp_ajuste_cont 
FROM TBL_SIF_ESTADO_CUENTA ec 
WHERE ec.fecha_datos BETWEEN $P{fecha_ini} AND $P{fecha_fin}
AND ec.id_moneda = $P{id_moneda}
AND ec.id_proceso = $P{id_proceso}
AND ec.cv_cliente = $P{clave_cliente}
AND ec.cv_negocio = $P{clave_negocio}
AND EXISTS (SELECT 'x' FROM TBL_SIF_SERVICIOS_FACTURAR sf 
WHERE sf.id_servicio = ec.id_servicio 
AND sf.id_cliente = ec.id_cliente 
AND sf.id_moneda = ec.id_moneda 
AND sf.fecha_datos BETWEEN $P{fecha_ini} AND $P{fecha_fin})
UNION
SELECT ec.id_moneda 
      ,ec.id_cliente 
	  ,ec.cv_cliente clave_cliente 
      ,ec.nm_cliente nombre_cliente 
	  ,ec.cv_negocio clave_negocio 
	  ,ec.nm_negocio nombre_negocio 
	  ,ec.id_servicio 
	  ,ec.cv_servicio||' '|| INITCAP(ec.nm_servicio) clave_servicio 
	  ,ec.semana 
	  ,ec.fecha_datos fecha 
      ,ec.dia 
	  ,ec.fecha_cobro 
	  ,0 trx 
	  ,ec.precio 
	  ,ec.tipo_cambio 
	  ,0 importe 
  	  ,0 iva 
      ,0 total 
      ,0 trx_ajuste_cont 
	  ,0 imp_ajuste_cont 
FROM TBL_SIF_ESTADO_CUENTA ec
WHERE ec.fecha_datos BETWEEN Pk_Sif_Dias_Periodo.obt_rango_edocta($P{fecha_ini},'MIN') AND Pk_Sif_Dias_Periodo.obt_rango_edocta($P{fecha_fin},'MAX')
AND ec.id_moneda = $P{id_moneda}
AND ec.id_proceso = $P{id_proceso}
AND ec.cv_cliente = $P{clave_cliente}
AND ec.cv_negocio = $P{clave_negocio}
AND EXISTS (SELECT 'x' FROM TBL_SIF_SERVICIOS_FACTURAR sf 
WHERE sf.id_servicio = ec.id_servicio 
AND sf.id_cliente = ec.id_cliente 
AND sf.id_moneda = ec.id_moneda 
AND sf.fecha_datos BETWEEN $P{fecha_ini} AND $P{fecha_fin})) det 
WHERE det.semana = $P{semana}
GROUP BY det.id_moneda 
      ,det.id_cliente 
	  ,det.clave_cliente 
      ,det.nombre_cliente 
	  ,det.clave_negocio 
	  ,det.nombre_negocio 
	  ,det.id_servicio 
	  ,det.clave_servicio 
	  ,det.semana 
	  ,det.fecha 
      ,det.dia 
	  ,det.fecha_cobro  
	  ,det.precio 
	  ,det.tipo_cambio
ORDER BY 10]]>
		</queryString>
		<field name="CLAVE_CLIENTE" class="java.lang.String"/>
		<field name="NOMBRE_CLIENTE" class="java.lang.String"/>
		<field name="CLAVE_NEGOCIO" class="java.lang.String"/>
		<field name="NOMBRE_NEGOCIO" class="java.lang.String"/>
		<field name="CLAVE_SERVICIO" class="java.lang.String"/>
		<field name="SEMANA" class="java.math.BigDecimal"/>
		<field name="FECHA" class="java.util.Date"/>
		<field name="TRX" class="java.math.BigDecimal"/>
		<field name="PRECIO" class="java.math.BigDecimal"/>
		<field name="IMPORTE" class="java.math.BigDecimal"/>
		<field name="IVA" class="java.math.BigDecimal"/>
		<field name="TIPO_CAMBIO" class="java.math.BigDecimal"/>
		<field name="FECHA_COBRO" class="java.util.Date"/>
		<field name="DIA" class="java.lang.String"/>
		<field name="TOTAL" class="java.math.BigDecimal"/>
		<field name="trx_ajuste_cont" class="java.math.BigDecimal"/>
		<field name="imp_ajuste_cont" class="java.math.BigDecimal"/>
	</subDataset>
	<subDataset name="SubDataset2" uuid="178ac126-8822-479a-89d1-07a1cace51c9">
		<parameter name="fecha_ini" class="java.util.Date" isForPrompting="false"/>
		<parameter name="fecha_fin" class="java.util.Date" isForPrompting="false"/>
		<parameter name="id_proceso" class="java.lang.Long" isForPrompting="false"/>
		<parameter name="id_negocio" class="java.lang.Long" isForPrompting="false"/>
		<parameter name="id_moneda" class="java.lang.Long" isForPrompting="false"/>
		<parameter name="clave_cliente" class="java.lang.String" isForPrompting="false"/>
		<queryString>
			<![CDATA[SELECT cv_cliente clave_cliente
      ,nm_cliente nombre_cliente
	  ,cv_negocio clave_negocio
	  ,nm_negocio nombre_negocio
	  ,cv_servicio ||' '|| INITCAP(nm_servicio) clave_servicio 
	  -- Total cobrado 
	  ,SUM(trx_cobranza) trx_cobranza 
	  ,SUM(imp_cobranza) importe_cobranza 
	  ,SUM(iva_cobranza) iva_cobranza 
      ,SUM(total_cobranza) total_cobranza
	  -- Facturacion real mensual 
	  ,SUM(trx_real) trx_real 
	  ,SUM(imp_real) importe_real
	  ,SUM(iva_real) iva_real 
	  ,SUM(total_real) total_real 
	  -- Diferencias 
	  ,SUM(trx_cobranza-trx_real) trx_dif
	  ,SUM(imp_cobranza-imp_real) importe_dif
	  ,SUM(iva_cobranza-iva_real) iva_dif
	  ,SUM(total_cobranza-total_real) total_dif
FROM TBL_SIF_COBRADO_VS_REAL cr
WHERE fecha_datos BETWEEN $P{fecha_ini} AND $P{fecha_fin}
and id_moneda = $P{id_moneda}
and id_proceso = $P{id_proceso}
and id_negocio = $P{id_negocio}
and cv_cliente = $P{clave_cliente}
GROUP BY cv_cliente 
         ,nm_cliente 
	 ,cv_negocio 
	 ,nm_negocio 
	 ,cv_servicio ||' '|| INITCAP(nm_servicio)]]>
		</queryString>
		<field name="CLAVE_CLIENTE" class="java.lang.String"/>
		<field name="NOMBRE_CLIENTE" class="java.lang.String"/>
		<field name="CLAVE_NEGOCIO" class="java.lang.String"/>
		<field name="NOMBRE_NEGOCIO" class="java.lang.String"/>
		<field name="CLAVE_SERVICIO" class="java.lang.String"/>
		<field name="TRX_COBRANZA" class="java.math.BigDecimal"/>
		<field name="IMPORTE_COBRANZA" class="java.math.BigDecimal"/>
		<field name="IVA_COBRANZA" class="java.math.BigDecimal"/>
		<field name="TOTAL_COBRANZA" class="java.math.BigDecimal"/>
		<field name="TRX_REAL" class="java.math.BigDecimal"/>
		<field name="IMPORTE_REAL" class="java.math.BigDecimal"/>
		<field name="IVA_REAL" class="java.math.BigDecimal"/>
		<field name="TOTAL_REAL" class="java.math.BigDecimal"/>
		<field name="TRX_DIF" class="java.math.BigDecimal"/>
		<field name="IMPORTE_DIF" class="java.math.BigDecimal"/>
		<field name="IVA_DIF" class="java.math.BigDecimal"/>
		<field name="TOTAL_DIF" class="java.math.BigDecimal"/>
	</subDataset>
